# ============================================================================
# Cloud9 ERP - Docker Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control
# ============================================================================

# ============================================================================
# Database Configuration
# ============================================================================
DB_USER=erp_user
DB_PASSWORD=erp_password
DB_NAME=erp_db
DB_PORT=5432

# ============================================================================
# JWT/Security Configuration
# ============================================================================
# Generate a secure secret key:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=your-super-secure-secret-key-change-this-in-production

# ============================================================================
# CORS Configuration
# ============================================================================
# For development:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# For production (update with your actual domain):
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com

# ============================================================================
# API Configuration
# ============================================================================
API_PORT=8000
VITE_API_URL=http://localhost:8000

# ============================================================================
# Frontend Configuration
# ============================================================================
FRONTEND_PORT=3000

# ============================================================================
# Environment Type
# ============================================================================
# Options: development, staging, production
ENVIRONMENT=development

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
DEBUG=false

# ============================================================================
# Production SSL/TLS
# ============================================================================
# Set to true when using HTTPS in production
USE_SSL=false

# Your domain for Let's Encrypt certificates
DOMAIN_NAME=yourdomain.com

# ============================================================================
# Email Configuration (Optional)
# ============================================================================
# If your application sends emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============================================================================
# AWS S3 Configuration (Optional)
# ============================================================================
# If using AWS S3 for file uploads
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_S3_BUCKET=your-bucket
AWS_S3_REGION=us-east-1

# ============================================================================
# Backup Configuration
# ============================================================================
# Backup retention period in days
BACKUP_RETENTION_DAYS=30
