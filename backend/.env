# APP_NAME=Cloud9 ERP
# DEBUG=true
# DATABASE_URL=sqlite:///./erp_local.db
# SQL_ECHO=false
# JWT_SECRET=bbbbbbbbbbbbbbbbbbbbbbbdev-secret-key-change-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_HOURS=24
# REFRESH_TOKEN_EXPIRATION_DAYS=30

# =============================================================================
# Cloud9 ERP - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control (only commit .env.example)
# For production deployments, use .env.production as the template.
# =============================================================================

# ============================================================
# REQUIRED: Database Configuration
# ============================================================
# SQLite (local development only):
#   DATABASE_URL=sqlite:///./erp_local.db
# PostgreSQL (recommended for production):
#   DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://erp_user:erp_password@64.227.191.1:5432/erp_db

# ============================================================
# REQUIRED: Application Security & JWT
# ============================================================
# Generate secure key: python -c "import secrets; print(secrets.token_urlsafe(48))"
# IMPORTANT: Use strong, random value (minimum 32 characters)
# CHANGE THIS IN PRODUCTION!
JWT_SECRET=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=30

# ============================================================
# REQUIRED: Application Settings
# ============================================================
APP_NAME=Cloud9 ERP
DEBUG=true                          # Set to false in production
LOG_LEVEL=DEBUG                     # DEBUG, INFO, WARNING, ERROR, CRITICAL
SQL_ECHO=false                      # Set to true to log all SQL queries (dev only)

# ============================================================
# REQUIRED: CORS Configuration (Frontend Access)
# ============================================================
# Comma-separated list of allowed origins for frontend requests
CORS_ORIGINS=http://64.227.191.1:5173,https://64.227.191.1:5173,http://localhost:5173,http://localhost:3000,http://localhost:8000

# ============================================================
# REQUIRED: Email Configuration (for vendor portal, order emails)
# ============================================================
# Choose ONE backend: smtp (development) or sendgrid (production)

# Option 1: SMTP (Development/Testing - Gmail, Office365, custom servers)
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.gmail.com            # Gmail example
SMTP_PORT=587                       # 587 for TLS, 465 for SSL
SMTP_USER=your-email@gmail.com      # Your email address
SMTP_PASSWORD=your-app-password     # Generate app-specific password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Option 2: SendGrid (Production - highly recommended)
# EMAIL_BACKEND=sendgrid
# SENDGRID_API_KEY=SG.your-api-key-here
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# OPTIONAL: Logging Configuration
# ============================================================
LOG_DIR=logs                        # Directory for log files (relative to backend/)
LOG_MAX_FILES=5                     # Max rotated log files to keep

# ============================================================
# OPTIONAL: Cloud Storage (for backups, document uploads)
# ============================================================
# Leave empty to use local disk storage in /uploads/ directory
# S3-compatible services: AWS S3, DigitalOcean Spaces, MinIO

# DigitalOcean Spaces (S3-compatible)
# DO_SPACES_KEY=your-spaces-access-key
# DO_SPACES_SECRET=your-spaces-secret-key
# DO_SPACES_BUCKET=cloud9-erp
# DO_SPACES_REGION=sfo3
# DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
# DO_SPACES_CDN_URL=https://cdn.yourdomain.com

# AWS S3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=cloud9erp-uploads
# AWS_S3_REGION=us-east-1
# AWS_S3_ENDPOINT=                  # Leave empty for standard AWS S3

# ============================================================
# OPTIONAL: APScheduler Configuration (for scheduled reports)
# ============================================================
# SCHEDULER_TIMEZONE=UTC
# SCHEDULED_REPORTS_CONFIG=data/scheduled_reports.json

# ============================================================
# OPTIONAL: Feature Flags
# ============================================================
# ENABLE_VENDOR_PORTAL=true
# ENABLE_ANALYTICS=true
# ENABLE_REPORTS=true
