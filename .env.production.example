# Cloud9 ERP - Production Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to Git

# Application Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=Cloud9 ERP

# Database Configuration
DB_USER=cloud9_user
DB_PASSWORD=your-secure-db-password-here
DB_NAME=cloud9_erp

# JWT & Authentication
JWT_SECRET=your-very-secure-random-secret-key-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Frontend Configuration
# Relative path - same origin, reverse-proxied by nginx. Do not use an absolute
# http:// URL here: it gets baked into the JS bundle and causes mixed-content
# errors on https pages.
VITE_API_URL=/api

# Backend Configuration
CORS_ORIGINS=https://erp.cloud9beverages.com
ALLOWED_HOSTS=erp.cloud9beverages.com,localhost,127.0.0.1

# DigitalOcean Spaces (Optional - for file uploads)
# DO_SPACES_ENABLED=true
# DO_SPACES_KEY=your-spaces-access-key
# DO_SPACES_SECRET=your-spaces-secret-key
# DO_SPACES_BUCKET=cloud9-erp-uploads
# DO_SPACES_REGION=sfo3
# DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
# DO_SPACES_CDN_URL=https://your-cdn-url.cdn.digitaloceanspaces.com

# Email Configuration (Optional)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# SMTP_FROM_EMAIL=noreply@cloud9beverages.com
